NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL (docker-compose.dev.yml)
DATABASE_URL=postgresql://domkrat:domkrat_dev_pass@localhost:5432/domkrat_dev?schema=public

# Auth (заполнятся в задачах 1.4-1.6)
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# CORS — все клиенты с Windows-машины + локальные dev
CORS_ORIGINS=http://192.168.1.8:3000,http://192.168.1.8:3002,http://192.168.1.8:3003,http://localhost:3000,http://localhost:3002,http://localhost:3003

# MVP providers (см. CLAUDE.md "MVP-подход")
SMS_PROVIDER=mock
PAYMENT_PROVIDERS=mock
EMAIL_TRANSPORT=mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
