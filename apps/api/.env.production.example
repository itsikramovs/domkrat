# =============================================================================
# Domkrat API — production environment template
# Скопировать в /etc/domkrat/api.env (или wherever secrets are kept)
# и не коммитить в git. Все CHANGE_ME должны быть заменены.
# =============================================================================

NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ----- БД -----
# PostgreSQL 16+, connection pool через PgBouncer рекомендуется
DATABASE_URL=postgresql://domkrat:CHANGE_ME_STRONG_PASSWORD@db.internal:5432/domkrat?schema=public&connection_limit=20&pool_timeout=20

# ----- Auth -----
# Сгенерировать: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_LONG_RANDOM_AT_LEAST_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
HOLD_DAYS=7

# ----- CORS -----
# Только домены production-фронтов
CORS_ORIGINS=https://domkrat.uz,https://m.domkrat.uz,https://merchant.domkrat.uz,https://admin.domkrat.uz

# ----- SMS провайдер -----
# 'eskiz' — Узбекистанский провайдер (https://eskiz.uz)
# 'mock' оставить для staging без отправки реальных SMS
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=noreply@domkrat.uz
ESKIZ_PASSWORD=CHANGE_ME
ESKIZ_SENDER=domkrat.uz

# ----- Email -----
EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.yandex.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@domkrat.uz
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM="Домкрат <noreply@domkrat.uz>"

# ----- Платежи -----
# MOCK — auto-success; COD — оплата при получении; остальные пока 501
PAYMENT_PROVIDERS=mock,cod,click,payme,uzum
CLICK_MERCHANT_ID=CHANGE_ME
CLICK_SECRET_KEY=CHANGE_ME
CLICK_SERVICE_ID=CHANGE_ME
PAYME_MERCHANT_ID=CHANGE_ME
PAYME_SECRET_KEY=CHANGE_ME

# ----- MinIO / S3 -----
# Если используется внешний S3 (DigitalOcean Spaces / AWS) — endpoint меняется
MINIO_INTERNAL_ENDPOINT=storage.internal
MINIO_PUBLIC_ENDPOINT=cdn.domkrat.uz
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=domkrat-uploads

# ----- Meilisearch -----
MEILI_HOST=http://search.internal:7700
MEILI_API_KEY=CHANGE_ME_64_CHAR_KEY
MEILI_PRODUCTS_INDEX=products

# ----- Sentry (опционально) -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- Redis (для BullMQ) -----
REDIS_URL=redis://:CHANGE_ME@cache.internal:6379

# ----- Rate-limiting (NestJS Throttler) -----
THROTTLE_TTL=60
THROTTLE_LIMIT=100
