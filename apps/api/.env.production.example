# =============================================================================
# Domkrat API — production environment template
# Скопировать в /etc/domkrat/api.env (или wherever secrets are kept)
# и не коммитить в git. Все CHANGE_ME должны быть заменены.
#
# Топология: ОДИН сервер. API, web/merchant/admin и инфра (Postgres/Redis/
# Meili/MinIO) живут на этом же хосте. Внутренние соединения — через 127.0.0.1,
# наружу всё отдаётся только через Cloudflare Tunnel (TLS на стороне Cloudflare).
# =============================================================================

NODE_ENV=production
PORT=3001
# Слушаем только loopback — снаружи доступ исключительно через Cloudflare Tunnel.
HOST=127.0.0.1

# ----- БД -----
# Postgres из docker-compose.production.yml, проброшен на 127.0.0.1:5432
DATABASE_URL=postgresql://domkrat:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/domkrat?schema=public&connection_limit=20&pool_timeout=20

# ----- Auth -----
# Сгенерировать: openssl rand -base64 64  (>= 64 случайных символов, без change_me/secret/example/dev)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_AT_LEAST_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
# Удержание средств мерчанта (дней). В production должно быть >= 1 (main.ts кидает Error при 0).
HOLD_DAYS=7

# ----- CORS -----
# Домены production-фронтов обоих доменов. Без localhost/192.168 — main.ts это запрещает в prod.
CORS_ORIGINS=https://domcrat.uz,https://www.domcrat.uz,https://merchant.domcrat.uz,https://admin.domcrat.uz,https://domkrat.uz,https://www.domkrat.uz,https://merchant.domkrat.uz,https://admin.domkrat.uz

# ----- SMS провайдер -----
# 'eskiz' — Узбекистанский провайдер (https://eskiz.uz)
# 'mock' оставить для тестового запуска без отправки реальных SMS
SMS_PROVIDER=mock
ESKIZ_EMAIL=noreply@domcrat.uz
ESKIZ_PASSWORD=CHANGE_ME
ESKIZ_SENDER=domcrat.uz

# ----- Email -----
# Для тестового запуска можно оставить MailHog (EMAIL_TRANSPORT=smtp, SMTP_HOST=127.0.0.1, SMTP_PORT=1025, SMTP_SECURE=false).
# Для боевого — реальный SMTP (Yandex/Mailgun/SendGrid).
EMAIL_TRANSPORT=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Домкрат <noreply@domcrat.uz>"

# ----- Платежи -----
# Для тестового запуска — mock,cod (auto-success / оплата при получении).
# Реальные click/payme/uzum пока 501-стабы; добавлять после интеграции.
PAYMENT_PROVIDERS=mock,cod
CLICK_MERCHANT_ID=CHANGE_ME
CLICK_SECRET_KEY=CHANGE_ME
CLICK_SERVICE_ID=CHANGE_ME
PAYME_MERCHANT_ID=CHANGE_ME
PAYME_SECRET_KEY=CHANGE_ME

# ----- MinIO / S3 -----
# Внутренний клиент (bucket ops) — напрямую к контейнеру на 127.0.0.1:9000, без TLS.
MINIO_INTERNAL_ENDPOINT=127.0.0.1
MINIO_INTERNAL_PORT=9000
MINIO_INTERNAL_USE_SSL=false
# Публичный клиент (presigned URL и публичные ссылки) — через Cloudflare на cdn.<домен>:443, TLS.
# Используем cdn основного тестового домена; ссылки на картинки будут на этом хосте.
MINIO_PUBLIC_ENDPOINT=cdn.domcrat.uz
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=domkrat-uploads

# ----- Meilisearch -----
# Контейнер на 127.0.0.1:7700
MEILI_HOST=http://127.0.0.1:7700
MEILI_API_KEY=CHANGE_ME_64_CHAR_KEY
MEILI_PRODUCTS_INDEX=products

# ----- Sentry (опционально) -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- Redis (для BullMQ) -----
# Контейнер на 127.0.0.1:6379, пароль из infra.env
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379

# ----- Rate-limiting (NestJS Throttler) -----
THROTTLE_TTL=60
THROTTLE_LIMIT=100
