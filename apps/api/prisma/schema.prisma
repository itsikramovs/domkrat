// Domkrat Prisma schema
//
// Источники:
//   - docs/04-DATABASE-SCHEMA.md (Auth/Users, Merchants, Catalog, Compatibility)
//   - docs/04-DATABASE-SCHEMA-PART2.md (Warehouse, Inventory, Orders, Payments,
//     Delivery, Finance, Notifications, CMS, Audit, System)
//
// MVP-упрощения:
//   - LTREE/GEOGRAPHY/INET/TSVECTOR → String/Float для совместимости с Prisma client.
//     Расширения (pg_trgm, ltree, postgis) можно подключить миграцией позже.
//   - Полнотекстовый поиск + материализованные пути категорий — Phase 2 через raw SQL.
//   - Партиционирование (stock_movements, orders, audit_logs) — Phase 2.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, citext]
}

