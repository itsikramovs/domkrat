# Domkrat Web (customer) — production
#
# ВАЖНО: NEXT_PUBLIC_* инлайнятся в бандл на этапе `pnpm build`, НЕ читаются в рантайме.
# Поэтому этот файл должен лежать как apps/web/.env.production ДО сборки —
# Next.js автоматически подхватывает .env.production при build и start.
# (systemd EnvironmentFile влияет только на рантайм-переменные вроде INTERNAL_API_URL.)
#
# Скопировать: cp apps/web/.env.production.example apps/web/.env.production

# Внутренний API URL — server components ходят сюда (рантайм, по loopback, быстро)
INTERNAL_API_URL=http://127.0.0.1:3001/api/v1

# Публичный API URL — браузер пользователя ходит сюда (через Cloudflare/HTTPS). Build-time.
NEXT_PUBLIC_API_URL=https://api.domcrat.uz/api/v1

# Канонический URL сайта (sitemap.xml, robots.txt, OG-meta). Build-time.
NEXT_PUBLIC_SITE_URL=https://domcrat.uz

# Опционально: телеметрия
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
