# Domkrat Web (customer) — production
# Скопировать в /etc/domkrat/web.env

# Внутренний API URL — server components ходят сюда (быстро, не через интернет)
INTERNAL_API_URL=http://api.internal:3001/api/v1

# Публичный API URL — браузер пользователя ходит сюда (через CDN/HTTPS)
NEXT_PUBLIC_API_URL=https://api.domkrat.uz/api/v1

# Опционально: телеметрия
NEXT_PUBLIC_SENTRY_DSN=
